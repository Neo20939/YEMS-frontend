# API Configuration
# Copy this file to .env.local and fill in your values

# ============================================================================
# External API Configuration
# ============================================================================

# External API Base URL for authentication and backend services
# Example: https://your-api.ngrok-free.dev
NEXT_PUBLIC_API_BASE_URL=https://kennedi-ungnostic-unconvulsively.ngrok-free.dev

# API Authentication (if required)
NEXT_PUBLIC_API_KEY=your-api-key-here

# Optional: API Secret for server-side operations
API_SECRET=your-api-secret-here

# API Timeout (milliseconds)
API_TIMEOUT=30000

# API Retries
API_RETRIES=3

# ============================================================================
# Authentication Endpoints (relative to BASE_URL)
# ============================================================================
# /api/auth/login   - User login
# /api/auth/logout  - User logout
# /api/auth/refresh - Refresh access token
# /api/auth/me      - Get current user info

